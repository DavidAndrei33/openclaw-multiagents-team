# Taskboard Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains sensitive tokens!

# ============================================
# TELEGRAM BOT TOKENS
# Get these from @BotFather on Telegram
# ============================================

# Product-Architect Bot Token (also used for owner notifications)
PRODUCT_ARCHITECT_BOT_TOKEN=your_product_architect_bot_token_here

# Backend-Architect Bot Token
BACKEND_ARCHITECT_BOT_TOKEN=your_backend_architect_bot_token_here

# Frontend-Architect Bot Token
FRONTEND_ARCHITECT_BOT_TOKEN=your_frontend_architect_bot_token_here

# Builder-Modules Bot Token
BUILDER_MODULES_BOT_TOKEN=your_builder_modules_bot_token_here

# Builder-Mobile Bot Token
BUILDER_MOBILE_BOT_TOKEN=your_builder_mobile_bot_token_here

# Reviewer-All Bot Token
REVIEWER_ALL_BOT_TOKEN=your_reviewer_all_bot_token_here

# Operations-All Bot Token
OPERATIONS_ALL_BOT_TOKEN=your_operations_all_bot_token_here

# Specialists-All Bot Token
SPECIALISTS_ALL_BOT_TOKEN=your_specialists_all_bot_token_here

# ============================================
# TELEGRAM CHAT IDs
# Get these by messaging @userinfobot on Telegram
# ============================================

# Owner Telegram Chat ID (for completion notifications)
OWNER_CHAT_ID=310970306

# Agent Chat IDs (optional - used for direct notifications)
# These can be discovered automatically when agents first interact with bots
PRODUCT_ARCHITECT_CHAT_ID=
BACKEND_ARCHITECT_CHAT_ID=
FRONTEND_ARCHITECT_CHAT_ID=
BUILDER_MODULES_CHAT_ID=
BUILDER_MOBILE_CHAT_ID=
REVIEWER_ALL_CHAT_ID=
OPERATIONS_ALL_CHAT_ID=
SPECIALISTS_ALL_CHAT_ID=

# ============================================
# WEBHOOK CONFIGURATION
# ============================================

# Base URL for webhooks (must be publicly accessible)
# For local development, use ngrok: https://ngrok.com/
# Example: https://your-domain.com or https://abc123.ngrok.io
WEBHOOK_BASE_URL=https://your-domain.com

# Webhook secret for security (optional)
# WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# FLASK CONFIGURATION
# ============================================

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=True

# Server host and port
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ============================================
# TASKBOARD CONFIGURATION
# ============================================

# How often to check for new tasks (in seconds)
TASK_CHECK_INTERVAL=5

# Enable/disable auto-notifications
AUTO_NOTIFY=true

# Enable/disable auto-backup before saves
AUTO_BACKUP=true

# ============================================
# OPTIONAL: DATABASE (for future use)
# Currently using JSON file, but can be extended
# ============================================
# DATABASE_URL=postgresql://user:password@localhost/taskboard
# REDIS_URL=redis://localhost:6379/0

# ============================================
# OPTIONAL: LOGGING
# ============================================
# LOG_LEVEL=INFO
# LOG_FILE=/var/log/taskboard.log